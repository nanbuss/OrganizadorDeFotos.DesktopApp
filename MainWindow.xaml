<Window x:Class="OrganizadorDeFotos.DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:OrganizadorDeFotos.DesktopApp.Views.Duplicates"
        xmlns:cleaning="clr-namespace:OrganizadorDeFotos.DesktopApp.Views.Cleaning"
        xmlns:explorer="clr-namespace:OrganizadorDeFotos.DesktopApp.Views.Explorer"
        xmlns:organization="clr-namespace:OrganizadorDeFotos.DesktopApp.Views.Organization"
        xmlns:preview="clr-namespace:OrganizadorDeFotos.DesktopApp.Views.Preview"
        Title="Organizador de Fotos" Height="700" Width="1200" Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra superior con selector de carpeta -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15">
            <DockPanel>
                <Label Content="Carpeta:" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" DockPanel.Dock="Left"/>
                <Button Content="Seleccionar Carpeta" Click="BrowseFolder_Click" Padding="12,8" Foreground="White" Background="#0078D4" FontSize="12" DockPanel.Dock="Right" Width="150"/>
                <TextBlock x:Name="FolderPathTextBlock" Text="Selecciona una carpeta..." VerticalAlignment="Center" Margin="10,0" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Contenedor principal con panel único para los tabs -->
        <Grid Grid.Row="1" Margin="15">

            <!-- Panel principal: TabControl con vistas -->
            <Border Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4">
                <TabControl x:Name="MainTabControl" Background="White" SelectionChanged="MainTabControl_SelectionChanged">
                    <!-- Tab 1: Explorador -->
                    <TabItem Header="Explorador" Background="White">
                        <explorer:ExplorerView x:Name="ExplorerViewControl" />
                    </TabItem>

                    <!-- Tab 2: Vista Preliminar -->
                    <TabItem Header="Vista Preliminar" Background="White">
                        <preview:PreviewView x:Name="PreviewViewControl" />
                    </TabItem>

                    <!-- Tab 3: Limpieza Inteligente -->
                    <TabItem Header="Limpieza" Background="White">
                        <cleaning:CleaningView x:Name="CleaningViewControl" />
                    </TabItem>

                    <!-- Tab 3: Duplicados -->
                    <TabItem Header="Duplicados" Background="White">
                        <views:DuplicatesView x:Name="DuplicatesViewControl" />
                    </TabItem>

                    <!-- Tab 4: Organización -->
                    <TabItem Header="Organización" Background="White">
                        <organization:OrganizationView x:Name="OrganizationViewControl" />
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- Panel de Notificaciones (Toast) -->
        <Border x:Name="NotificationPanel" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top" 
                Background="#2C3E50" BorderBrush="#27AE60" BorderThickness="0,3,0,0" CornerRadius="4" 
                Padding="15" Margin="20" MaxWidth="350" Opacity="0" IsHitTestVisible="False">
            <TextBlock x:Name="NotificationText" Text="" Foreground="White" TextWrapping="Wrap" FontSize="12"/>
        </Border>
    </Grid>
</Window>
