<UserControl x:Class="OrganizadorDeFotos.DesktopApp.Views.Organization.OrganizationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OrganizadorDeFotos.DesktopApp.Views.Organization"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12">
            <TextBlock Text="Organización Estructural (Vista Previa Virtual)" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel Izquierdo: Estructura Virtual -->
            <Border Grid.Column="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#F9F9F9" IsEnabled="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsFolderLoaded}">
                        <Button x:Name="AddFolderButton" Content="📁+" ToolTip="Nueva Carpeta" Click="AddFolder_Click" Margin="5" Padding="5,2" Background="#EEEEEE"/>
                        <Button x:Name="RenameFolderButton" Content="✏️" ToolTip="Renombrar" Click="RenameFolder_Click" Margin="0,5,5,5" Padding="5,2" Background="#EEEEEE"/>
                        <Button x:Name="DeleteFolderButton" Content="🗑️" ToolTip="Eliminar" Click="DeleteFolder_Click" Margin="0,5,5,5" Padding="5,2" Background="#EEEEEE"/>
                        <Button x:Name="AutoOrganizeButton" Content="🪄 Auto-Organizar" ToolTip="Auto-Organizar por Fecha" Click="AutoOrganize_Click" Margin="0,5,5,5" Padding="5,2" Background="#EEEEEE"/>
                    </StackPanel>

                    <TreeView Grid.Row="1" x:Name="FolderTreeView" BorderThickness="0" 
                              SelectedItemChanged="FolderTreeView_SelectedItemChanged"
                              AllowDrop="True"
                              DragEnter="FolderTreeView_DragEnter"
                              DragOver="FolderTreeView_DragOver"
                              DragLeave="FolderTreeView_DragLeave"
                              Drop="FolderTreeView_Drop"
                              PreviewMouseLeftButtonDown="FolderTreeView_PreviewMouseLeftButtonDown"
                              MouseMove="FolderTreeView_MouseMove">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding SubFolders}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁" Margin="0,0,5,0" Foreground="#FFC107"/>
                                    <TextBlock Text="{Binding Name}"/>
                                    <TextBlock Text="{Binding TotalCount, StringFormat=' ({0})'}" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Separador -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <!-- Panel Derecho: Fotos -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F9F9F9" Padding="10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="CurrentPathLabel" Text="Selecciona una carpeta para ver fotos" VerticalAlignment="Center" Foreground="#666"/>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="1" x:Name="FilesListBox" SelectionMode="Extended" BorderThickness="0" Background="Transparent" Padding="10" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         PreviewMouseLeftButtonDown="FilesListBox_PreviewMouseLeftButtonDown"
                         MouseMove="FilesListBox_MouseMove">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="160" Margin="5" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="5">
                                <StackPanel>
                                    <Image Source="{Binding ImageSource}" Height="120" Stretch="UniformToFill"/>
                                    <TextBlock Text="{Binding FileName}" FontSize="10" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="10">
                    <Grid>
                        <TextBlock x:Name="SelectionInfoLabel" Text="0 fotos seleccionadas" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="AssignToFolderButton" Content="Mover fotos seleccionadas..." Click="AssignToFolder_Click" Padding="10,5" Margin="0,0,10,0"/>
                            <Button x:Name="FinalizeButton" Content="🚀 Finalizar y Mover Archivos" Click="Finalize_Click" Padding="15,5" Background="#2E7D32" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Overlay de carga -->
        <Border x:Name="LoadingOverlay" Grid.Row="1" Grid.ColumnSpan="3" Background="#88FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="10" Margin="0,0,0,10"/>
                <TextBlock Text="Cargando estructura..." HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
